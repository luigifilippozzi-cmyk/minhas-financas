rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica se o usuário está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é membro de um grupo
    function isMemberOfGroup(grupoId) {
      return isSignedIn() &&
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.grupoId == grupoId;
    }

    // Usuários: só pode ler/escrever o próprio perfil
    match /usuarios/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Grupos: qualquer autenticado pode criar e ler (necessário para busca por
    // código de convite); atualização permitida a membros OU para entrar no
    // grupo via código (usuário adiciona-se à lista de membros sem remover outros).
    match /grupos/{grupoId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        // Membros existentes podem alterar qualquer campo
        isMemberOfGroup(grupoId) ||
        // Novo usuário pode entrar: só adiciona-se a membros, não remove ninguém,
        // e o grupo ainda não está cheio.
        (
          request.resource.data.membros.hasAll(resource.data.membros) &&
          request.auth.uid in request.resource.data.membros &&
          !(request.auth.uid in resource.data.membros) &&
          resource.data.membros.size() < resource.data.maxMembros
        )
      );
    }

    // Categorias: apenas membros do grupo
    match /categorias/{categoriaId} {
      allow read, write: if isSignedIn() && isMemberOfGroup(resource.data.grupoId);
      allow create: if isSignedIn() && isMemberOfGroup(request.resource.data.grupoId);
    }

    // Despesas: apenas membros do grupo
    match /despesas/{despesaId} {
      allow read, write: if isSignedIn() && isMemberOfGroup(resource.data.grupoId);
      allow create: if isSignedIn() && isMemberOfGroup(request.resource.data.grupoId);
    }

    // Orçamentos: apenas membros do grupo
    match /orcamentos/{orcamentoId} {
      allow read, write: if isSignedIn() && isMemberOfGroup(resource.data.grupoId);
      allow create: if isSignedIn() && isMemberOfGroup(request.resource.data.grupoId);
    }

    // Parcelamentos: apenas membros do grupo
    match /parcelamentos/{parcId} {
      allow read: if isSignedIn() && isMemberOfGroup(resource.data.grupoId);
      allow create: if isSignedIn() && isMemberOfGroup(request.resource.data.grupoId);
      allow update: if isSignedIn() && isMemberOfGroup(resource.data.grupoId);
      allow delete: if false;
    }

    // Contas/Bancos: apenas membros do grupo (NRF-004)
    match /contas/{contaId} {
      allow read, write: if isSignedIn() && isMemberOfGroup(resource.data.grupoId);
      allow create: if isSignedIn() && isMemberOfGroup(request.resource.data.grupoId);
    }

    // Receitas: apenas membros do grupo (RF-016)
    match /receitas/{receitaId} {
      allow read, write: if isSignedIn() && isMemberOfGroup(resource.data.grupoId);
      allow create: if isSignedIn() && isMemberOfGroup(request.resource.data.grupoId);
    }
  }
}
